# Copy this file to .env and adjust as needed.

# Option A — Vite proxy (recommended for local dev, no CORS issues)
VITE_RECORDS_API=/api/records.php

# Option B — Direct PHP server URL (if not using the proxy)
# VITE_RECORDS_API=http://localhost:8080/api/records.php

# Option C — Any external server
# VITE_RECORDS_API=https://your-server.example.com/api/records.php
